{
  "servers": [
    {
      "name": "Frontend (Vite)",
      "command": "npm run dev",
      "cwd": "frontend",
      "host": "127.0.0.1",
      "port": 5173
    },
    {
      "name": "Backend (Uvicorn)",
      "command": "uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
      "cwd": ".",
      "host": "127.0.0.1",
      "port": 8000
    }
  ]
}
