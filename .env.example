# Security
# JWT_SECRET must be a secure random string in production.
# On Render, the backend refuses to start if this is missing or set to "change-me".
# Generate a good value with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
APP_LOG_LEVEL=INFO
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440

# Frontend / CORS
# Must include scheme (https://). Used for CORS, email links, and OAuth redirects.
FRONTEND_BASE_URL=https://marketmetrics.dev
ADDITIONAL_FRONTEND_ORIGINS=http://127.0.0.1:8000,http://127.0.0.1:5173,http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://marketmetrics.onrender.com/auth/google/callback

# Email / Brevo
# If BREVO_API_KEY is not set, the backend logs email actions instead of sending.
BREVO_API_KEY=your_brevo_api_key_here
BREVO_TRANSACTIONAL_EMAIL_URL=https://api.brevo.com/v3/smtp/email
BREVO_TIMEOUT_SECONDS=20
EMAIL_FROM_NAME=MarketMetrics
EMAIL_FROM_ADDRESS=your_verified_brevo_sender@example.com

# Database
# Required on Render. Local dev defaults to SQLite if not set.
DATABASE_URL=postgresql://user:password@your-render-postgres-host/your_database_name

# Alpaca Market Data
# All market data (quotes, bars, movers, snapshots) comes from Alpaca.
ALPACA_API_KEY=alpaca_api_key
ALPACA_SECRET_KEY=alpaca_secret_key
ALPACA_DATA_FEED=iex
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets

# Local Data Paths
SYMBOL_CATALOG_PATH=data/symbol_catalog.json
PREDICTION_MODEL_DIR=artifacts/prediction

# Forecasting / Training
PREDICTION_TRAINING_LOOKBACK_DAYS=1825
PREDICTION_FETCH_CONCURRENCY=5
PREDICTION_TRAINING_UNIVERSE=
PREDICTION_TRAINING_UNIVERSE_PATH=data/training_universe.json
MARKET_DATA_DEFAULT_HISTORY_DAYS=3650
