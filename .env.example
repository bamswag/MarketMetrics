# Security
# JWT_SECRET must be a secure random string in production.
# On Render, the backend refuses to start if this is missing or set to "change-me".
# Generate a good value with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
APP_LOG_LEVEL=
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=

# Frontend / CORS
# Must include scheme (https://). Used for CORS, email links, and OAuth redirects.
FRONTEND_BASE_URL=
ADDITIONAL_FRONTEND_ORIGINS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Email / Brevo
# If BREVO_API_KEY is not set, the backend logs email actions instead of sending.
BREVO_API_KEY=
BREVO_TRANSACTIONAL_EMAIL_URL=
BREVO_TIMEOUT_SECONDS=
EMAIL_FROM_NAME=
EMAIL_FROM_ADDRESS=
# Database
# Required on Render. Local dev defaults to SQLite if not set.
DATABASE_URL=

# Alpaca Market Data
# All market data (quotes, bars, movers, snapshots) comes from Alpaca.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_DATA_FEED=
ALPACA_DATA_BASE_URL=
ALPACA_TRADING_BASE_URL=

# Local Data Paths
SYMBOL_CATALOG_PATH=
PREDICTION_MODEL_DIR=

# Forecasting / Training
PREDICTION_TRAINING_LOOKBACK_DAYS=
PREDICTION_FETCH_CONCURRENCY=
PREDICTION_TRAINING_UNIVERSE=
PREDICTION_TRAINING_UNIVERSE_PATH=
MARKET_DATA_DEFAULT_HISTORY_DAYS=
